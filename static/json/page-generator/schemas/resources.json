{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "const": "resources"
    },
    "data": {
      "type": "object",
      "required": ["title", "blocks"],
      "properties": {
        "title": { "$ref": "#/definitions/titleObject" },
        "padding": { "enum": ["deep", "shallow", "default"] },
        "blocks": {
          "type": "array",
          "contains": { "$ref": "#/definitions/resourcesBlock" },
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/descriptionBlock" },
              { "$ref": "#/definitions/ctaBlock" },
              { "$ref": "#/definitions/resourcesBlock" }
            ]
          }
        }
      }
    }
  },
  "definitions": {
    "titleObject": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "link_attrs": {
          "type": "object",
          "properties": {
            "href": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "descriptionBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "description" },
        "padding": { "enum": ["shallow"] },
        "item": {
          "type": "object",
          "required": ["type", "content"],
          "properties": {
            "type": { "enum": ["text", "html"] },
            "content": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "ctaBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "cta-block" },
        "padding": { "enum": ["shallow"] },
        "item": {
          "type": "object",
          "properties": {
            "primary": { "$ref": "#/definitions/linkObject" },
            "secondaries": {
              "type": "array",
              "items": { "$ref": "#/definitions/linkObject" }
            },
            "link": { "$ref": "#/definitions/linkObject" }
          },
          "anyOf": [
            { "required": ["primary"] },
            { "required": ["secondaries"] },
            { "required": ["link"] }
          ]
        }
      }
    },
    "linkObject": {
      "type": "object",
      "required": ["content_html", "attrs"],
      "properties": {
        "content_html": { "type": "string" },
        "attrs": {
          "type": "object",
          "properties": {
            "href": { "type": "string" }
          }
        }
      }
    },
    "resourcesBlock": {
      "type": "object",
      "required": ["categories"],
      "properties": {
        "type": { "const": "resources" },
        "render_images": { "type": "boolean" },
        "render_categories": { "type": "boolean" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "items"],
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["title"],
                  "properties": {
                    "title": { "$ref": "#/definitions/titleObject" },
                    "description": {
                      "type": "object",
                      "required": ["text"],
                      "properties": {
                        "text": { "type": "string" },
                        "attrs": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        }
                      },
                      "additionalProperties": false
                    },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "authors": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["text"],
                            "properties": {
                              "text": { "type": "string" },
                              "link_attrs": {
                                "type": "object",
                                "properties": {
                                  "href": { "type": "string" }
                                }
                              }
                            }
                          }
                        },
                        "date": {
                          "type": "object",
                          "required": ["text"],
                          "properties": {
                            "text": { "type": "string" },
                            "link": {
                              "type": "object",
                              "properties": {
                                "href": { "type": "string" }
                              }
                            }
                          }
                        }
                      },
                      "additionalProperties": false
                    },
                    "image": {
                      "type": "object",
                      "properties": {
                        "type": { "enum": ["default", "logo"] },
                        "attrs": {
                          "type": "object",
                          "required": ["src"],
                          "properties": {
                            "src": { "type": "string" },
                            "alt": { "type": "string" }
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
