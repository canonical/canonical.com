# Placeholder card macro for knowledge hub category pages. This should be replaced with the actual Card pattern once it is ready.
{% macro vf_card(
  link='#',
  heading='Card title',
  footer='Card footer',
  columns=2
) %}
  <div class="grid-col-{{ columns }}">
    <div class="p-card u-no-padding">
      <div class="p-card__inner">
        <a href="{{ link }}" class="p-link--soft">
          <h4>{{ heading }}</h4>
        </a>
      </div>
      <hr class="p-rule--muted u-no-margin--bottom">
      <div class="p-card__inner">
        <span class="p-chip--information is-readonly u-no-margin--bottom">
          <span class="p-chip__value">{{ footer.content_type }}</span>
        </span>
      </div>
    </div>
  </div>

{% endmacro %}