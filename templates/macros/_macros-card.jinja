{%- macro vf_card(title, link, tag, tag_link) -%}
  <div class="p-card u-no-padding">
    <div class="p-card__inner">
      <h4>
        <a href="{{ link }}">{{ title }}</a>
      </h4>
    </div>
    <hr class="u-no-margin--bottom">
    <div class="p-card__inner">
      by <a href="#">Bartek Szopka</a> on 21st August 2021
    </div>
  </div>
  </div>
{%- endmacro -%}